{
  "expo": {
    "scheme": "khumbaya",
    "name": "khumbaya",
    "slug": "khumbaya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/home.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aaditya-lamichhane.khumbaya"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/home.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "2fc43e7a-14bc-48b0-93f2-b96986ee5427"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/screen.png",
          "imageWidth": 200,
          "contentFit": "cover",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Khumbaya to use your location to show your business on the map.",
          "locationWhenInUsePermission": "Allow Khumbaya to use your location to show your business on the map."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/screen.png",
        "backgroundImage": "./assets/images/screen.png",
        "monochromeImage": "./assets/images/screen.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aaditya_lamichhane.khumbaya",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2fc43e7a-14bc-48b0-93f2-b96986ee5427"
    }
  }
}
